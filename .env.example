APP_NAME="Techurja Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=techurja_admin
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Admin Authentication (set a strong secret)
ADMIN_PASSWORD=change_me_in_production

# FTP Configuration
FTP_HOST=ftp.example.com
FTP_USERNAME=ftpuser
FTP_PASSWORD=ftppassword
FTP_PORT=21
FTP_ROOT=/registrations
FTP_PASSIVE=true
FTP_SSL=false
FTP_TIMEOUT=30
